{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": {
    "gleam":  "latest",
    "erlang": "latest",
    "rebar3": "latest",
    "inotify-tools": {
      "version":   "latest",
      "platforms": ["aarch64-linux", "x86_64-linux"]
    }
  },
  "shell": {
    "init_hook": [
      "gleam deps download"
    ],
    "scripts": {
      "test": [
        "echo \"Error: no test specified\" && exit 1"
      ],
      "dev": [
        "gleam run -m lustre/dev start"
      ]
    }
  }
}
